# Supabase / PostgreSQL Connection
DATABASE_URL=postgresql://postgres.USER:PASSWORD@HOST:PORT/postgres

# Discord OAuth
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
# Comma-separated list of Discord IDs that should have admin access
ADMIN_DISCORD_IDS=id1,id2

# URL of the client-side application (no trailing slash)
CLIENT_URL=http://localhost:5173

# Session secret (long random string)
SESSION_SECRET=your_session_secret

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get your webhook secret by running 'stripe listen --forward-to localhost:3000/api/payment/webhook'
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Product Catalog in Stripe Dashboard)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# Discord Bot Configuration
# Bot must have 'Manage Roles' and 'Server Members' intent enabled
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_guild_id

# Free Trial Configuration (in minutes)
TRIAL_DURATION_MINUTES=5

# Discord Role IDs
# Ensure the bot's role is HIGHER than these roles in the server settings
DISCORD_ROLE_BREAD_BRO=id
